ANTHROPIC_API_KEY=

# Instagram API with Instagram Login (graph.instagram.com) — NOT the Facebook-Login Graph API.
# Get Instagram App ID/Secret from Meta App > Instagram > "API setup with Instagram login".
META_APP_ID=
META_APP_SECRET=
# Long-lived Instagram-Login token, IGAA... prefix (expires ~60 days; refresh via
# graph.instagram.com/refresh_access_token?grant_type=ig_refresh_token)
INSTAGRAM_ACCESS_TOKEN=
# Instagram-scoped account ID returned by the token exchange (NOT the App ID)
IG_USER_ID=

# Supabase — project Settings > API
# Use the service-role key (not anon/publishable) for backend agent access
SUPABASE_URL=
SUPABASE_KEY=
# Postgres connection string for LangGraph checkpointer (Connect > Session pooler;
# URL-encode special chars in the password, e.g. @ -> %40, ^ -> %5E)
SUPABASE_DB_URL=
# Public Storage bucket for post images (Instagram fetches image_url server-side)
SUPABASE_BUCKET=voodoo-momo-artifacts

# Google AI Studio — Gemini image generation (Nano Banana). Requires billing enabled
# on the project; image models are not on the free tier.
GOOGLE_API_KEY=

# Composio — composio.dev dashboard
COMPOSIO_API_KEY=

# Langfuse — cloud.langfuse.com project Settings > API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
