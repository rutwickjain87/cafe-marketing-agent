ANTHROPIC_API_KEY=

# LLM provider routing (src/llm.py). anthropic | openrouter (default: openrouter).
# OpenRouter lets you run any model (e.g. GLM) through one OpenAI-compatible API.
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
# OpenRouter model slug; see openrouter.ai/models (default: z-ai/glm-5.2)
OPENROUTER_MODEL=z-ai/glm-5.2

# Instagram API with Instagram Login (graph.instagram.com) — NOT the Facebook-Login Graph API.
# Get Instagram App ID/Secret from Meta App > Instagram > "API setup with Instagram login".
META_APP_ID=
META_APP_SECRET=
# Long-lived Instagram-Login token, IGAA... prefix (expires ~60 days; refresh via
# graph.instagram.com/refresh_access_token?grant_type=ig_refresh_token)
INSTAGRAM_ACCESS_TOKEN=
# Instagram-scoped account ID returned by the token exchange (NOT the App ID)
IG_USER_ID=

# Supabase — project Settings > API
# Use the service-role key (not anon/publishable) for backend agent access
SUPABASE_URL=
SUPABASE_KEY=
# Postgres connection string for LangGraph checkpointer (Connect > Session pooler;
# URL-encode special chars in the password, e.g. @ -> %40, ^ -> %5E)
SUPABASE_DB_URL=
# Public Storage bucket for post images (Instagram fetches image_url server-side)
SUPABASE_BUCKET=voodoo-momo-artifacts

# fal.ai — image + video generation. fal.ai/dashboard/keys
FAL_KEY=
# Optional overrides; defaults shown.
FAL_VIDEO_MODEL=          # fal-ai/kling-video/v2/standard/image-to-video
FAL_IMAGE_MODEL=          # fal-ai/flux/dev  (product shots)
FAL_IMAGE_EDIT_MODEL=     # fal-ai/flux-pro/kontext  (mascot reference consistency)
# Image backend selector; default "fal". See src/tools/image_providers/.
IMAGE_PROVIDER=

# Telegram — phone approval + ops alerts. Bot token from @BotFather; chat id of the operator.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Operator API (FastAPI) — n8n authenticates with this shared secret (X-Operator-Token).
# Also used to authenticate the fal webhook (passed as a ?token= query param).
OPERATOR_API_TOKEN=
# Public HTTPS base URL of the operator API — used to build fal + Meta webhook URLs.
PUBLIC_BASE_URL=
# Meta webhook verification token (you choose this; it must match the Meta App webhook config).
META_WEBHOOK_VERIFY_TOKEN=

# Composio — composio.dev dashboard
COMPOSIO_API_KEY=

# Langfuse (LLM tracing, SDK v4) — cloud.langfuse.com project Settings > API Keys.
# Tracing is enabled only when LANGFUSE_PUBLIC_KEY is set; otherwise a no-op.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# In-process scheduler (APScheduler) — replaces n8n's cron.
SCHEDULER_ENABLED=true
DISPATCH_INTERVAL_MINUTES=5
# Daily auto-kickoff (opt-in): drafts one post/day at 09:00 UTC, paused for approval.
DAILY_KICKOFF_ENABLED=false
DAILY_KICKOFF_PRODUCT=

# Multi-post fan-out: publish time-of-day for each calendar post (week_start + day_offset).
POST_HOUR=10          # 0–23, local hour posts are scheduled for; default 10
POST_TZ=Asia/Kolkata  # IANA tz for POST_HOUR; default Asia/Kolkata
