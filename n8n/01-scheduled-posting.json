{
  "name": "Voodoo Momo — Scheduled Posting",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "minutes", "minutesInterval": 5 }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Every 5 minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [260, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.OPERATOR_API_URL }}/scheduled/dispatch",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Operator-Token", "value": "={{ $env.OPERATOR_API_TOKEN }}" }
          ]
        },
        "options": {}
      },
      "id": "dispatch-due",
      "name": "Dispatch due posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 9 * * *" }
          ]
        }
      },
      "id": "daily-trigger",
      "name": "Daily 9am kickoff (optional)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [260, 540]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.OPERATOR_API_URL }}/campaigns",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Operator-Token", "value": "={{ $env.OPERATOR_API_TOKEN }}" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"brief\": {\n    \"goal\": \"daily product spotlight\",\n    \"format\": \"feed_post\",\n    \"duration_days\": 1\n  }\n}",
        "options": {}
      },
      "id": "start-campaign",
      "name": "Start campaign",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 540]
    }
  ],
  "connections": {
    "Every 5 minutes": {
      "main": [[{ "node": "Dispatch due posts", "type": "main", "index": 0 }]]
    },
    "Daily 9am kickoff (optional)": {
      "main": [[{ "node": "Start campaign", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "meta": {
    "description": "Polls the operator API every 5 min to publish posts whose scheduled_at is due, and (optionally) kicks off one campaign each morning. Set OPERATOR_API_URL and OPERATOR_API_TOKEN as n8n environment variables."
  }
}
